# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.

# ------------------------------------------------------------------
# Discogs
# Generate your token at: https://www.discogs.com/settings/developers
# ------------------------------------------------------------------
DISCOGS_TOKEN=your_discogs_personal_access_token_here
DISCOGS_USERNAME=your_discogs_username_here

# ------------------------------------------------------------------
# Lidarr
# Find your API key at: Lidarr → Settings → General → Security
# ------------------------------------------------------------------
LIDARR_URL=http://localhost:8686
LIDARR_API_KEY=your_lidarr_api_key_here

# ------------------------------------------------------------------
# Lidarr defaults applied when adding new artists / albums
# Profile IDs are not shown in the Lidarr UI. To find them, set
# LIDARR_URL and LIDARR_API_KEY above, then run:
#   uv run discogs-lidarr-sync profiles
# That command prints a table of all profiles and their numeric IDs.
# ------------------------------------------------------------------
LIDARR_ROOT_FOLDER=/music
LIDARR_QUALITY_PROFILE_ID=1
LIDARR_METADATA_PROFILE_ID=1

# ------------------------------------------------------------------
# MusicBrainz lookup cache
# Results are cached here to avoid re-querying on repeated runs.
# Path is relative to the project root. Gitignored.
# ------------------------------------------------------------------
MBZ_CACHE_PATH=.cache/mbz_cache.json
