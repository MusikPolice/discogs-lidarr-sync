# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.

# ------------------------------------------------------------------
# Discogs
# Generate your token at: https://www.discogs.com/settings/developers
# ------------------------------------------------------------------
DISCOGS_TOKEN=your_discogs_personal_access_token_here
DISCOGS_USERNAME=your_discogs_username_here

# ------------------------------------------------------------------
# Lidarr
# Find your API key at: Lidarr → Settings → General → Security
# ------------------------------------------------------------------
LIDARR_URL=http://localhost:8686
LIDARR_API_KEY=your_lidarr_api_key_here

# ------------------------------------------------------------------
# Lidarr defaults applied when adding new artists / albums
# Profile IDs are not shown in the Lidarr UI. To find them, set
# LIDARR_URL and LIDARR_API_KEY above, then run:
#   uv run discogs-lidarr-sync profiles
# That command prints a table of all profiles and their numeric IDs.
# ------------------------------------------------------------------
LIDARR_ROOT_FOLDER=/music
LIDARR_QUALITY_PROFILE_ID=1
LIDARR_METADATA_PROFILE_ID=1

# ------------------------------------------------------------------
# Spotify
# Create your app at: https://developer.spotify.com/dashboard
# Add redirect URI exactly: http://127.0.0.1:8888/callback
# (note: 127.0.0.1 — Spotify no longer accepts "localhost")
# ------------------------------------------------------------------
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# If spotify-sync returns 403 when creating the playlist, Spotify's API is
# restricting playlist creation for dev-mode apps.  Workaround:
#   1. Create the playlist manually in the Spotify app
#   2. Open it → ··· → Share → Copy link to playlist
#      URL format: https://open.spotify.com/playlist/{PLAYLIST_ID}
#   3. Paste the ID below and uncomment the line
# SPOTIFY_PLAYLIST_ID=

# Optional Spotify paths (defaults shown):
# SPOTIFY_TOKEN_CACHE_PATH=.cache/spotify_token
# SPOTIFY_SEARCH_CACHE_PATH=.cache/spotify_cache.json

# ------------------------------------------------------------------
# MusicBrainz lookup cache
# Results are cached here to avoid re-querying on repeated runs.
# Path is relative to the project root. Gitignored.
# ------------------------------------------------------------------
MBZ_CACHE_PATH=.cache/mbz_cache.json
